{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
    ],
    "automerge": true,
    "automergeStrategy": "squash",
    "rebaseWhen": "conflicted",
    "customManagers": [
        // trivy version in workflow call
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/^.github/workflows/supply-chain-security-validation.yaml$/"
            ],
            "matchStrings": ["aquasecurity/trivy-action@.*\\n\\s+with:[\\s\\S]*?version:\\s*(?<currentValue>v[0-9.]+)"],
            "datasourceTemplate": "github-releases",
            "depNameTemplate": "aquasecurity/trivy",
            "versioningTemplate": "semver"
        },
        // enry version in setup enry step
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/^.github/workflows/supply-chain-security-validation.yaml$/"
            ],
            "matchStrings": ["ENRY_VERSION:\\s*(?<currentValue>v[0-9.]+)"],
            "datasourceTemplate": "github-releases",
            "depNameTemplate": "go-enry/enry",
            "versioningTemplate": "semver"
        },
    ],
}
